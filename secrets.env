OP_AWS_ACCESS_KEY=op://ai-agent-army/AWS/access_key
OP_AWS_SECRET_KEY=op://ai-agent-army/AWS/secret_access_key
OP_SA_TOKEN=op://ai-agent-army/OnePassword/service_account_token
